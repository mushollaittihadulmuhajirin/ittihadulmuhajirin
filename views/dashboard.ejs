Jenis Aset

</p>

</div>

</div>

<div class="col-md-3 col-6 mb-3">

<div class="inventory-card text-center">

<div class="icon mb-2">

📦

</div>

<h3>

<%= total_barang %>

</h3>

<p>

Unit Barang

</p>

</div>

</div>

<div class="col-md-3 col-6 mb-3">

<div class="inventory-card text-center">

<div class="icon mb-2">

💵

</div>

<h3>

Rp <%= Number(nilai_aset).toLocaleString("id-ID") %>

</h3>

<p>

Nilai Inventaris

</p>

</div>

</div>

<div class="col-md-3 col-6 mb-3">

<div class="inventory-card text-center">

<div class="icon mb-2">

📈

</div>

<h3>

Rp <%= Number(saldo).toLocaleString("id-ID") %>

</h3>

<p>

Saldo Kas

</p>

</div>

</div>

</div>

</div>



<!-- =============================
CHART SCRIPT
============================== -->

<script>

const ctx = document.getElementById("grafikKeuangan");

new Chart(ctx, {

    type: "bar",

    data: {

        labels: [
            "Pemasukan",
            "Pengeluaran",
            "Saldo"
        ],

        datasets: [{

            label: "Nilai (Rp)",

            data: [
                <%= pemasukan %>,
                <%= pengeluaran %>,
                <%= saldo %>
            ],

            backgroundColor: [
                "#198754",
                "#dc3545",
                "#0d6efd"
            ],

            borderRadius: 10,

            borderSkipped: false

        }]

    },

    options: {

        responsive: true,

        maintainAspectRatio: false,

        plugins: {

            legend: {

                display: false

            },

            tooltip: {

                callbacks: {

                    label: function(context){

                        return "Rp " +
                        Number(context.raw).toLocaleString("id-ID");

                    }

                }

            }

        },

        scales: {

            y: {

                beginAtZero: true,

                ticks: {

                    callback: function(value){

                        return "Rp " +
                        Number(value).toLocaleString("id-ID");

                    }

                }

            }

        }

    }

});

</script>

