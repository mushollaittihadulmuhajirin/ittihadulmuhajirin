<!DOCTYPE html>
<html>
<head>
    <title>Dashboard DKM</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

<div class="container mt-4">

    <h2>Dashboard Keuangan Masjid</h2>

    <div class="row mt-4">

        <div class="col-md-4">
            <div class="card text-bg-success">
                <div class="card-body">
                    <h5>Saldo Saat Ini</h5>
                    <h3>Rp <%= Number(saldo).toLocaleString('id-ID') %></h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-bg-primary">
                <div class="card-body">
                    <h5>Total Pemasukan</h5>
                    <h3>Rp <%= Number(pemasukan).toLocaleString('id-ID') %></h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-bg-danger">
                <div class="card-body">
                    <h5>Total Pengeluaran</h5>
                    <h3>Rp <%= Number(pengeluaran).toLocaleString('id-ID') %></h3>
                </div>
            </div>
        </div>

    </div>

    <div class="card mt-4">
        <div class="card-body">

            <canvas id="grafik"></canvas>

        </div>
    </div>

</div>

<script>

const ctx = document.getElementById("grafik");

new Chart(ctx, {
    type: "bar",
    data: {
        labels: ["Jan", "Feb", "Mar", "Apr"],
        datasets: [{
            label: "Pemasukan",
            data: [1000000, 2000000, 1500000, 3000000]
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: true
    }
});

</script>
</body>
</html>