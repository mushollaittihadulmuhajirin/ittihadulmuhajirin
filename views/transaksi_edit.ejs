<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">
<title>Edit Transaksi</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

body{
    background:#f4f6f9;
}

.card{
    border:none;
    border-radius:15px;
    box-shadow:0 3px 12px rgba(0,0,0,.15);
}

.card-header{
    border-radius:15px 15px 0 0!important;
}

</style>

</head>

<body>

<div class="container mt-4">

<div class="card">

<div class="card-header bg-warning text-dark">

<h3 class="mb-0">
<i class="fa-solid fa-pen-to-square"></i>
Edit Transaksi
</h3>

</div>

<div class="card-body">

<form action="/transaksi/update/<%= data.id %>" method="POST">

<div class="row">

<div class="col-md-4 mb-3">

<label class="form-label">
Tanggal
</label>

<input
type="date"
name="tanggal"
class="form-control"
value="<%= new Date(data.tanggal).toISOString().slice(0,10) %>"
required>

</div>

<div class="col-md-4 mb-3">

<label class="form-label">
Jenis
</label>

<select
name="jenis"
class="form-select">

<option
value="masuk"
<%= data.jenis=="masuk"?"selected":"" %>>

Pemasukan

</option>

<option
value="keluar"
<%= data.jenis=="keluar"?"selected":"" %>>

Pengeluaran

</option>

</select>

</div>

<div class="col-md-4 mb-3">

<label class="form-label">
Rekening
</label>

<select
name="rekening_id"
class="form-select">

<option value="">-- Pilih Rekening --</option>

<% rekening.forEach(function(r){ %>

<option
value="<%= r.id %>"
<%= data.rekening_id==r.id ? "selected" : "" %>>

<%= r.bank %> - <%= r.nama_pemilik %>

</option>

<% }) %>

</select>

</div>

</div>

<div class="mb-3">

<label class="form-label">
Kategori
</label>

<select
name="kategori_id"
class="form-select">

<% kategori.forEach(function(k){ %>

<option
value="<%= k.id %>"
<%= data.kategori_id==k.id ? "selected":"" %>>

<%= k.nama %>

</option>

<% }) %>

</select>

</div>

<div class="mb-3">

<label class="form-label">
Nominal
</label>

<input
type="number"
name="nominal"
class="form-control"
value="<%= data.nominal %>"
required>

</div>

<div class="mb-4">

<label class="form-label">
Keterangan
</label>

<textarea
name="keterangan"
rows="4"
class="form-control"><%= data.keterangan %></textarea>

</div>

<button class="btn btn-success">

<i class="fa-solid fa-floppy-disk"></i>
Simpan Perubahan

</button>

<a
href="/transaksi"
class="btn btn-secondary">

<i class="fa-solid fa-arrow-left"></i>
Kembali

</a>

</form>

</div>

</div>

</div>

</body>

</html>