<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<title>Edit Donasi Barang</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#f4f6f9;
}

.card{
    border-radius:15px;
}

</style>

</head>

<body>

<div class="container mt-4">

<div class="card shadow">

<div class="card-header bg-warning">

<h3 class="mb-0">
✏ Edit Donasi Barang
</h3>

</div>

<div class="card-body">

<form action="/transaksi/update-donasi/<%= data.id %>" method="POST">

<div class="row">

<div class="col-md-4 mb-3">

<label class="form-label">
Tanggal
</label>

<input
type="date"
name="tanggal"
class="form-control"
value="<%= new Date(data.tanggal).toISOString().slice(0,10) %>"
required>

</div>

<div class="col-md-8 mb-3">

<label class="form-label">
Nama Donatur
</label>

<input
type="text"
name="nama_donatur"
class="form-control"
value="<%= data.nama_donatur %>"
required>

</div>

</div>

<div class="row">

<div class="col-md-6 mb-3">

<label class="form-label">
Nama Barang
</label>

<input
type="text"
name="nama_barang"
class="form-control"
value="<%= data.nama_barang %>"
required>

</div>

<div class="col-md-6 mb-3">

<label class="form-label">
Kategori
</label>

<select
name="kategori"
class="form-select">

<% kategori.forEach(function(k){ %>

<option
value="<%= k.nama %>"
<%= data.kategori==k.nama ? "selected" : "" %>>

<%= k.nama %>

</option>

<% }) %>

</select>

</div>

</div>

<div class="row">

<div class="col-md-3 mb-3">

<label class="form-label">
Jumlah
</label>

<input
type="number"
name="jumlah"
class="form-control"
value="<%= data.jumlah %>">

</div>

<div class="col-md-3 mb-3">

<label class="form-label">
Satuan
</label>

<input
type="text"
name="satuan"
class="form-control"
value="<%= data.satuan %>">

</div>

<div class="col-md-3 mb-3">

<label class="form-label">
Kondisi
</label>

<select
name="kondisi"
class="form-select">

<option
value="Baru"
<%= data.kondisi=="Baru" ? "selected" : "" %>>

Baru

</option>

<option
value="Bekas"
<%= data.kondisi=="Bekas" ? "selected" : "" %>>

Bekas

</option>

</select>

</div>

<div class="col-md-3 mb-3">

<label class="form-label">
Estimasi Harga
</label>

<input
type="number"
name="estimasi_harga"
class="form-control"
value="<%= data.estimasi_harga %>">

</div>

</div>

<div class="mb-3">

<label class="form-label">
Keterangan
</label>

<textarea
name="keterangan"
class="form-control"
rows="3"><%= data.keterangan %></textarea>

</div>

<div class="text-end">

<button
class="btn btn-success">

💾 Simpan Perubahan

</button>

<a
href="/transaksi"
class="btn btn-secondary">

Batal

</a>

</div>

</form>

</div>

</div>

</div>

</body>

</html>