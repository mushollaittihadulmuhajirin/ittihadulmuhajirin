<%- include("partials/header",{title:"Master Kategori"}) %>

<%- include("partials/navbar") %>

<style>

.shadow-soft{
    border:none;
    border-radius:15px;
    box-shadow:0 5px 18px rgba(0,0,0,.08);
}

.page-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:25px;
}

.dashboard-title{
    font-weight:700;
}

</style>

<div class="container-fluid">

<div class="page-header">

<div>

<h2 class="dashboard-title">

📂 Master Kategori

</h2>

<small class="text-muted">

Kategori Transaksi • Donasi Barang • Inventaris

</small>

</div>

</div>

<!-- ===================================================== -->
<!-- FORM TAMBAH KATEGORI -->
<!-- ===================================================== -->

<div class="card shadow-soft mb-4">

<div class="card-header bg-success text-white">

<h5 class="mb-0">

➕ Tambah Kategori

</h5>

</div>

<div class="card-body">

<form
action="/kategori/simpan"
method="POST">

<div class="row">

<div class="col-md-5 mb-3">

<label class="form-label">

Nama Kategori

</label>

<input
type="text"
class="form-control"
name="nama"
placeholder="Contoh : Karpet Masjid"
required>

</div>

<div class="col-md-4 mb-3">

<label class="form-label">

Jenis Kategori

</label>

<select
id="tipe"
class="form-select"
name="tipe"
required>

<option value="">

-- Pilih Jenis --

</option>

<option value="uang">

💰 Transaksi Uang

</option>

<option value="donasi">

🎁 Donasi Barang

</option>

<option value="inventaris">

📦 Inventaris

</option>

</select>

</div>

<div class="col-md-3 mb-3 d-flex align-items-end">

<button
type="submit"
class="btn btn-success w-100">

💾 Simpan Kategori

</button>

</div>

</div>

</form>

</div>

</div>
<!-- ===================================================== -->
<!-- DAFTAR KATEGORI -->
<!-- ===================================================== -->

<div class="card shadow-soft">

    <div class="card-header bg-primary text-white">

        <h5 class="mb-0">

            📋 Daftar Kategori

        </h5>

    </div>

    <div class="card-body table-responsive">

        <table class="table table-bordered table-hover align-middle">

            <thead class="table-light">

                <tr>

                    <th width="60">No</th>

                    <th>Nama Kategori</th>

                    <th width="220">Jenis</th>

                    <th width="180">Aksi</th>

                </tr>

            </thead>

            <tbody>

            <% if(data && data.length){ %>

                <% data.forEach(function(item,index){ %>

                <tr>

                    <td>

                        <%= index+1 %>

                    </td>

                    <td>

                        <strong><%= item.nama %></strong>

                    </td>

                    <td>

                        <% if(item.tipe==="uang"){ %>

                            <span class="badge bg-success">

                                💰 Transaksi Uang

                            </span>

                        <% }else if(item.tipe==="donasi"){ %>

                            <span class="badge bg-warning text-dark">

                                🎁 Donasi Barang

                            </span>

                        <% }else if(item.tipe==="inventaris"){ %>

                            <span class="badge bg-primary">

                                📦 Inventaris

                            </span>

                        <% }else{ %>

                            <span class="badge bg-secondary">

                                Belum Ditentukan

                            </span>

                        <% } %>

                    </td>

                    <td>

                        <a
                        href="/kategori/edit/<%= item.id %>"
                        class="btn btn-warning btn-sm">

                            ✏ Edit

                        </a>

                        <a
                        href="/kategori/hapus/<%= item.id %>"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Hapus kategori ini?')">

                            🗑 Hapus

                        </a>

                    </td>

                </tr>

                <% }) %>

            <% }else{ %>

                <tr>

                    <td colspan="4" class="text-center text-muted">

                        Belum ada kategori.

                    </td>

                </tr>

            <% } %>

            </tbody>

        </table>

    </div>

</div>

</div>
