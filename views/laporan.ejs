<!DOCTYPE html>
<html>

<head>

<title>Laporan Keuangan</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>

body{
    background:#f4f6f9;
}


.header{
    background:#198754;
    color:white;
    padding:20px;
    border-radius:10px;
    margin-bottom:20px;
}


.card{
    border-radius:15px;
    color:white;
    box-shadow:0 3px 10px #aaa;
}


.masuk{
    background:#198754;
}


.keluar{
    background:#dc3545;
}


.saldo{
    background:#0d6efd;
}


.table thead{
    background:#198754;
    color:white;
}


</style>

</head>


<body>


<div class="container mt-4">



<div class="header">

<h2>
🕌 DKM Ittihadul Muhajirin
</h2>

<h4>
📊 Laporan Keuangan Masjid
</h4>

<p>
Rekap pemasukan dan pengeluaran
</p>

</div>




<div class="row mb-4">



<div class="col-md-4">

<div class="card masuk p-4">

<h5>Total Masuk</h5>

<h3>
Rp <%= masuk.toLocaleString('id-ID') %>
</h3>

</div>

</div>




<div class="col-md-4">

<div class="card keluar p-4">

<h5>Total Keluar</h5>

<h3>
Rp <%= keluar.toLocaleString('id-ID') %>
</h3>

</div>

</div>




<div class="col-md-4">

<div class="card saldo p-4">

<h5>Saldo</h5>

<h3>
Rp <%= saldo.toLocaleString('id-ID') %>
</h3>

</div>

</div>

</div>
<div class="card mt-4 p-3 bg-white">

<h4 class="text-dark mb-3">
📈 Grafik Keuangan Masjid
</h4>

<canvas id="grafikLaporan"></canvas>

</div>




<div class="card p-3 bg-white">


<div class="table-responsive">
<table class="table table-bordered">


<thead>

<tr>

<th>Tanggal</th>
<th>Kategori</th>
<th>Jenis</th>
<th>Metode</th>
<th>Nominal</th>
<th>Keterangan</th>

</tr>

</thead>


<tbody>


<% data.forEach(item=>{ %>


<tr>


<td>

<%= new Date(item.tanggal).toLocaleDateString('id-ID',{
weekday:'long',
day:'2-digit',
month:'long',
year:'numeric'
}) %>

</td>


<td>
<%= item.kategori_nama %>
</td>


<td>

<%= item.jenis %>

</td>


<td>

<%= item.metode %>

</td>


<td>

Rp <%= Number(item.nominal).toLocaleString('id-ID') %>

</td>


<td>

<%= item.keterangan %>

</td>


</tr>


<% }) %>


</tbody>


</table>


</div>

</div>


<br>


<a href="/" class="btn btn-success">

⬅ Dashboard

</a>



</div>
<script>

const ctx = document.getElementById("grafikLaporan");

new Chart(ctx, {
    type: "bar",
    data: {
        labels: ["Pemasukan", "Pengeluaran", "Saldo"],
        datasets: [{
            label: "Keuangan Masjid",
            data: [
                <%= masuk %>,
                <%= keluar %>,
                <%= saldo %>
            ]
        }]
    },
    options: {
        responsive: true
    }
});

</script>

</body>

</html>