<div class="container mt-4">

<h3>🔑 Ubah Password</h3>

<form action="/ubah-password" method="POST">

<div class="mb-3">
<label>Password Lama</label>
<input
type="password"
name="password_lama"
class="form-control"
required>
</div>

<div class="mb-3">
<label>Password Baru</label>
<input
type="password"
name="password_baru"
class="form-control"
required>
</div>

<div class="mb-3">
<label>Konfirmasi Password Baru</label>
<input
type="password"
name="konfirmasi"
class="form-control"
required>
</div>

<button class="btn btn-success">

<i class="fa-solid fa-floppy-disk"></i>

Simpan

</button>

</form>

</div>