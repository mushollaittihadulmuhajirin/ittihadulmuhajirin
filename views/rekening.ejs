<!DOCTYPE html>
<html>
<head>

<title>Master Rekening</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-4">

<h2>🏦 Master Rekening Masjid</h2>

<div class="mb-3">

    <a href="/dashboard" class="btn btn-dark">
📈 Dashboard
</a>

<a href="/transaksi" class="btn btn-primary">
💰 Transaksi
</a>

<a href="/rekening" class="btn btn-info">
🏦 Rekening
</a>

<a href="/kategori" class="btn btn-warning">
📂 Kategori
</a>

<a href="/laporan" class="btn btn-success">
📊 Laporan
</a>

<a href="/" class="btn btn-secondary">
🏠 Halaman Utama
</a>

<a href="/login/logout" class="btn btn-danger">
🚪 Logout
</a>

</div>

<hr>

<form method="POST" action="/rekening/simpan">

<div class="mb-2">
<label>Nama Pemilik</label>
<input type="text" name="nama_pemilik" class="form-control" required>
</div>

<div class="mb-2">
<label>Bank</label>
<input type="text" name="bank" class="form-control" required>
</div>

<div class="mb-2">
<label>No Rekening</label>
<input type="text" name="no_rekening" class="form-control" required>
</div>

<div class="mb-2">
<label>Keterangan</label>
<textarea name="keterangan" class="form-control"></textarea>
</div>

<button class="btn btn-success">
Simpan
</button>

</form>

<hr>

<h4>Data Rekening</h4>

<table class="table table-bordered">

<thead class="table-info">

<tr>
<th>ID</th>
<th>Nama Pemilik</th>
<th>Bank</th>
<th>No Rekening</th>
<th>Aksi</th>
</tr>

</thead>

<tbody>

<% data.forEach(item => { %>

<tr>

<td><%= item.id %></td>
<td><%= item.nama_pemilik %></td>
<td><%= item.bank %></td>
<td><%= item.no_rekening %></td>

<td>

<a
href="/rekening/hapus/<%= item.id %>"
class="btn btn-danger btn-sm"
onclick="return confirm('Hapus data?')">

Hapus

</a>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>