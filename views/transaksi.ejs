placeholder="Unit">

</div>

<div class="col-md-3 mb-3">

<label class="form-label">

Kondisi

</label>

<select
class="form-select"
name="kondisi">

<option value="Baik">Baik</option>

<option value="Bekas">Bekas</option>

<option value="Service">Service</option>

</select>

</div>

<div class="col-md-5 mb-3">

<label class="form-label">

Lokasi

</label>

<input
