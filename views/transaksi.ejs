Nilai Estimasi

</label>

<input
type="number"
class="form-control"
name="nilai_estimasi"
value="0">

</div>

<div class="col-md-8 mb-3">

<label class="form-label">

Keterangan

</label>

<input
type="text"
class="form-control"
name="keterangan">

</div>

</div>

<div class="text-end">

<button
type="submit"
class="btn btn-success">

💾 Simpan Inventaris

</button>

<button
