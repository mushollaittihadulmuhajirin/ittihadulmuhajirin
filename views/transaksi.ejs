id="tanggal_inventaris"
name="tanggal_masuk"
required>

</div>

<div class="col-md-5 mb-3">

<label class="form-label">

Nama Aset

</label>

<input
type="text"
class="form-control"
name="nama_barang"
required>

</div>

<div class="col-md-4 mb-3">

<label class="form-label">

Kategori

</label>

<select
class="form-select"
name="kategori">

<option value="">-- Pilih Kategori --</option>

<% kategori.forEach(function(k){ %>

<% if(k.tipe==="inventaris"){ %>

<option value="<%= k.nama %>">

<%= k.nama %>

</option>

<% } %>

<% }) %>

</select>

</div>

</div>

<div class="row">

<div class="col-md-2 mb-3">

<label class="form-label">

Jumlah

</label>

<input
type="number"
class="form-control"
name="jumlah"
value="1">

</div>

<div class="col-md-2 mb-3">

<label class="form-label">

Satuan

</label>

<input
type="text"
class="form-control"
