<%- include("partials/header",{title:"Transaksi DKM"}) %>

<%- include("partials/navbar") %>

<style>

.page-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:25px;
}

.dashboard-title{
    font-weight:700;
}

.shadow-soft{
    border:none;
    border-radius:15px;
    box-shadow:0 5px 18px rgba(0,0,0,.08);
}

.form-section{
    display:none;
}

.table td{
    vertical-align:middle;
}

.badge{
    font-size:13px;
}

</style>

<div class="container-fluid">

<div class="page-header">

<div>

<h2 class="dashboard-title">

💰 Input Transaksi DKM

</h2>

<small class="text-muted">

Keuangan • Donasi Barang • Inventaris Masjid

</small>

</div>

</div>

<!-- ===================================================== -->
<!-- RINGKASAN -->
<!-- ===================================================== -->

<div class="row mb-4">

<div class="col-lg-4">

<div class="card shadow-soft">

<div class="card-body text-center">

<h6>Saldo Kas</h6>

<h3 class="text-success">

Rp <%= Number(saldo||0).toLocaleString("id-ID") %>

</h3>

</div>

</div>

</div>

<div class="col-lg-4">

<div class="card shadow-soft">

<div class="card-body text-center">

<h6>Total Pemasukan</h6>

<h3 class="text-primary">

Rp <%= Number(pemasukan||0).toLocaleString("id-ID") %>

</h3>

</div>

</div>

</div>

<div class="col-lg-4">

<div class="card shadow-soft">

<div class="card-body text-center">

<h6>Total Pengeluaran</h6>

<h3 class="text-danger">

Rp <%= Number(pengeluaran||0).toLocaleString("id-ID") %>

</h3>

</div>

</div>

</div>

</div>

<!-- ===================================================== -->
<!-- FORM -->
<!-- ===================================================== -->

<div class="card shadow-soft">

<div class="card-body">

<div class="row mb-3">

<div class="col-md-4">

<label class="form-label fw-bold">

Jenis Input

</label>

<select
class="form-select"
id="jenis_input">

<option value="uang">

💰 Transaksi Uang

</option>

<option value="donasi">

🎁 Donasi Barang

</option>

<option value="inventaris">

📦 Inventaris

</option>

</select>

</div>

</div>

<hr>

<!-- ===================================================== -->
<!-- FORM UANG -->
<!-- ===================================================== -->

<div
id="formUang"
class="form-section">

<form
action="/transaksi/simpan"
method="POST">

<input
type="hidden"
name="tipe_transaksi"
value="uang">

<div class="row">

<div class="col-md-3 mb-3">

<label class="form-label">

Tanggal

</label>

<input
type="date"
class="form-control"
id="tanggal_uang"
name="tanggal"
required>

</div>

<div class="col-md-3 mb-3">

<label class="form-label">

Jenis

</label>

<select
class="form-select"
name="jenis">

<option value="masuk">

Pemasukan

</option>

<option value="keluar">

Pengeluaran

</option>

</select>

</div>

<div class="col-md-3 mb-3">

<label class="form-label">

Kategori

</label>

<select
class="form-select"
name="kategori_id"
required>

<option value="">

-- Pilih Kategori --

</option>

<% kategori.forEach(function(k){ %>

<% if(k.tipe==="uang"){ %>

<option value="<%= k.id %>">

<%= k.nama %>

</option>

<% } %>

<% }) %>

</select>

</div>

<div class="col-md-3 mb-3">

<label class="form-label">

Metode

</label>

<select
class="form-select"
name="metode"
id="metode">

<option value="tunai">

💵 Tunai

</option>

<option value="transfer">

🏦 Non Tunai

</option>

</select>

</div>

</div>

<div class="row">

<div
class="col-md-4 mb-3"
id="rekeningGroup">

<label class="form-label">

Rekening

</label>

<select
class="form-select"
name="rekening_id"
id="rekening_id">

<option value="">

-- Pilih Rekening --

</option>

<% rekening.forEach(function(r){ %>

<option value="<%= r.id %>">

<%= r.bank %> - <%= r.nama_pemilik %>

</option>

<% }) %>

</select>

</div>

<div class="col-md-4 mb-3">

<label class="form-label">

Nominal

</label>

<input
type="number"
class="form-control"
name="nominal"
required>

</div>

<div class="col-md-4 mb-3">

<label class="form-label">

Keterangan

</label>

<input
type="text"
class="form-control"
name="keterangan">

</div>

</div>

<div class="text-end">

<button
class="btn btn-success">

💾 Simpan Transaksi

</button>

<button
type="reset"
class="btn btn-secondary">

Reset

</button>

</div>

</form>

</div>

<!-- ===================================================== -->
<!-- FORM DONASI BARANG -->

<!-- ===================================================== -->
<!-- FORM DONASI BARANG -->
<!-- ===================================================== -->

<div
id="formDonasi"
class="form-section">

<form
action="/transaksi/simpan"
method="POST">

<input
type="hidden"
name="tipe_transaksi"
value="donasi">

<div class="row">

<div class="col-md-3 mb-3">

<label class="form-label">

Tanggal

</label>

<input
type="date"
class="form-control"
id="tanggal_donasi"
name="tanggal"
required>

</div>

<div class="col-md-5 mb-3">

<label class="form-label">

Nama Donatur

</label>

<input
type="text"
class="form-control"
name="nama_donatur"
required>

</div>

<div class="col-md-4 mb-3">

<label class="form-label">

Kategori

</label>

<select
class="form-select"
name="kategori">

<option value="">-- Pilih Kategori --</option>

<% kategori.forEach(function(k){ %>

<% if(k.tipe==="donasi"){ %>

<option value="<%= k.nama %>">

<%= k.nama %>

</option>

<% } %>

<% }) %>

</select>

</div>

</div>

<div class="row">

<div class="col-md-6 mb-3">

<label class="form-label">

Nama Barang

</label>

<input
type="text"
class="form-control"
name="nama_barang"
required>

</div>

<div class="col-md-2 mb-3">

<label class="form-label">

Jumlah

</label>

<input
type="number"
class="form-control"
name="jumlah"
value="1">

</div>

<div class="col-md-2 mb-3">

<label class="form-label">

Satuan

</label>

<input
type="text"
class="form-control"
name="satuan"
placeholder="Pcs">

</div>

<div class="col-md-2 mb-3">

<label class="form-label">

Kondisi

</label>

<select
class="form-select"
name="kondisi">

<option value="Baru">Baru</option>

<option value="Bekas">Bekas</option>

</select>

</div>

</div>

<div class="row">

<div class="col-md-4 mb-3">

<label class="form-label">

Estimasi Harga

</label>

<input
type="number"
class="form-control"
name="estimasi_harga"
value="0">

</div>

<div class="col-md-8 mb-3">

<label class="form-label">

Keterangan

</label>

<input
type="text"
class="form-control"
name="keterangan">

</div>

</div>

<div class="text-end">

<button
type="submit"
class="btn btn-success">

💾 Simpan Donasi Barang

</button>

<button
type="reset"
class="btn btn-secondary">

Reset

</button>

</div>

</form>

</div>

<!-- ===================================================== -->
<!-- FORM INVENTARIS -->
<!-- ===================================================== -->

<div
id="formInventaris"
