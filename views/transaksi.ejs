<!DOCTYPE html>
<html>
<head>

<title>Transaksi DKM</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-4">

<h2>Input Transaksi</h2>
<div class="mb-3">

    <a href="/dashboard" class="btn btn-dark">
📈 Dashboard
</a>

<a href="/transaksi" class="btn btn-primary">
💰 Transaksi
</a>

<a href="/rekening" class="btn btn-info">
🏦 Rekening
</a>

<a href="/kategori" class="btn btn-warning">
📂 Kategori
</a>

<a href="/laporan" class="btn btn-success">
📊 Laporan
</a>

<a href="/" class="btn btn-secondary">
🏠 Halaman Utama
</a>

<a href="/login/logout" class="btn btn-danger">
🚪 Logout
</a>

</div>

<hr>



<form method="POST" action="/transaksi/simpan">

<div class="mb-2">
<label>Tanggal</label>
<input type="date" name="tanggal" class="form-control" required>
</div>

<div class="mb-2">
<label>Kategori</label>

<select name="kategori_id" class="form-control" required>

<option value="">
Pilih Kategori
</option>

<% kategori.forEach(item => { %>

<option value="<%= item.id %>">
<%= item.nama %>
</option>

<% }) %>

</select>
</div>

<div class="mb-2">
<label>Jenis</label>

<select name="jenis" class="form-control">

<option value="masuk">
Pemasukan
</option>

<option value="keluar">
Pengeluaran
</option>

</select>

</div>

<div class="mb-2">
<label>Metode Pembayaran</label>

<select
name="metode"
id="metode"
class="form-control">

<option value="tunai">
Tunai
</option>

<option value="non_tunai">
Non Tunai
</option>

</select>
</div>

<div
class="mb-2"
id="rekeningArea"
style="display:none;">

<label>Pilih Rekening</label>

<select
name="rekening_id"
class="form-control">

<option value="">
Pilih Rekening
</option>

<% rekening.forEach(item => { %>

<option value="<%= item.id %>">
<%= item.bank %> - <%= item.no_rekening %>
</option>

<% }) %>

</select>

</div>

<div class="mb-2">
<label>Nominal</label>
<input type="number" name="nominal" class="form-control" required>
</div>

<div class="mb-2">
<label>Keterangan</label>
<textarea name="keterangan" class="form-control"></textarea>
</div>

<button class="btn btn-success">
Simpan
</button>

</form>

<hr>

<h3>Data Transaksi</h3>

<div class="table-responsive">
<table class="table table-bordered">

<thead>
<tr>
<th>ID</th>
<th>Tanggal</th>
<th>Jenis</th>
<th>Metode</th>
<th>Nominal</th>
<th>Keterangan</th>
<th>Aksi</th>
</tr>
</thead>

<tbody>

<% data.forEach(item => { %>

<tr>

<td><%= item.id %></td>
<td><%= new Date(item.tanggal).toLocaleDateString('id-ID',{
    weekday:'long',
    day:'2-digit',
    month:'long',
    year:'numeric'
}) %></td>
<td><%= item.jenis %></td>
<td><%= item.metode || '-' %></td>

<td>
Rp <%= Number(item.nominal).toLocaleString('id-ID') %>
</td>

<td><%= item.keterangan %></td>

<td>

<a
href="/transaksi/hapus/<%= item.id %>"
class="btn btn-danger btn-sm"
onclick="return confirm('Hapus data?')">

Hapus

</a>

</td>

</tr>

<% }) %>

</tbody>

</table>
</div>
</div>
<script>

document.addEventListener("DOMContentLoaded", function(){

const metode = document.getElementById("metode");
const rekeningArea = document.getElementById("rekeningArea");


metode.addEventListener("change", function(){

    if(this.value === "non_tunai"){

        rekeningArea.style.display = "block";

    }else{

        rekeningArea.style.display = "none";

    }

});

});

</script>