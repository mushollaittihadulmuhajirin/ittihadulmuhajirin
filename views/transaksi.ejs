class="btn btn-secondary">

Reset

</button>

</div>

</form>

</div>
<!-- ===================================================== -->
<!-- RIWAYAT TRANSAKSI UANG -->
<!-- ===================================================== -->

<div class="card shadow-soft mt-4">

    <div class="card-header bg-success text-white">

        <h5 class="mb-0">

            💰 Riwayat Transaksi Uang

        </h5>

    </div>

    <div class="card-body table-responsive">

        <table class="table table-bordered table-hover align-middle">

            <thead class="table-light">

                <tr>

                    <th width="40">No</th>

                    <th>Tanggal</th>

                    <th>Jenis</th>

                    <th>Kategori</th>

                    <th>Metode</th>

                    <th>Rekening</th>

                    <th class="text-end">Nominal</th>

                    <th>Keterangan</th>

                    <th width="170">Aksi</th>

                </tr>

            </thead>

            <tbody>

            <% if(transaksi && transaksi.length){ %>

                <% transaksi.forEach(function(item,index){ %>

                <tr>

                    <td>

                        <%= index+1 %>

                    </td>

                    <td>

                        <%= new Date(item.tanggal).toLocaleDateString("id-ID") %>

                    </td>

                    <td>

                        <% if(item.jenis==="masuk"){ %>

                            <span class="badge bg-success">

                                Pemasukan

                            </span>

                        <% }else{ %>

                            <span class="badge bg-danger">

                                Pengeluaran

                            </span>

                        <% } %>

                    </td>

                    <td>

                        <%= item.kategori || "-" %>

                    </td>

                    <td>

                        <% if(item.metode==="transfer"){ %>

                            <span class="badge bg-primary">

                                Non Tunai

                            </span>

                        <% }else{ %>

                            <span class="badge bg-secondary">

                                Tunai

                            </span>

                        <% } %>

                    </td>

                    <td>

                        <% if(item.metode==="transfer"){ %>

                            <%= item.nama_rekening || "-" %>

                        <% }else{ %>

                            -

                        <% } %>

                    </td>

                    <td class="text-end">

                        Rp <%= Number(item.nominal||0).toLocaleString("id-ID") %>

                    </td>

                    <td>

                        <%= item.keterangan || "-" %>

                    </td>

                    <td>

                        <a
                        href="/transaksi/edit/<%= item.id %>"
                        class="btn btn-warning btn-sm">

                            ✏ Edit

                        </a>

                        <a
                        href="/transaksi/hapus/<%= item.id %>"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Hapus transaksi ini?')">

                            🗑 Hapus

                        </a>

                    </td>

                </tr>

                <% }) %>

            <% }else{ %>

                <tr>

                    <td colspan="9" class="text-center text-muted">

                        Belum ada transaksi.

                    </td>

                </tr>

            <% } %>

            </tbody>

        </table>

    </div>

</div>

<!-- ===================================================== -->
<!-- RIWAYAT DONASI BARANG -->
<!-- ===================================================== -->

<div class="card shadow-soft mt-4">

    <div class="card-header bg-warning">

        <h5 class="mb-0">

            🎁 Riwayat Donasi Barang

        </h5>

    </div>

    <div class="card-body table-responsive">

        <table class="table table-bordered table-hover align-middle">

            <thead class="table-light">

                <tr>

                    <th width="40">No</th>

                    <th>Tanggal</th>

                    <th>Donatur</th>

                    <th>Barang</th>

                    <th>Kategori</th>

                    <th>Jumlah</th>

                    <th>Kondisi</th>

                    <th class="text-end">Estimasi</th>

                    <th>Keterangan</th>

                    <th width="170">Aksi</th>

                </tr>

            </thead>

            <tbody>

            <% if(donasi && donasi.length){ %>

                <% donasi.forEach(function(item,index){ %>

                <tr>

                    <td>

                        <%= index+1 %>

                    </td>

                    <td>

                        <%= new Date(item.tanggal).toLocaleDateString("id-ID") %>

                    </td>

                    <td>

                        <%= item.nama_donatur || "-" %>

                    </td>

                    <td>

                        <strong>

                            <%= item.nama_barang %>

                        </strong>

                    </td>

                    <td>

                        <%= item.kategori || "-" %>

                    </td>

                    <td>

                        <%= item.jumlah %> <%= item.satuan %>

                    </td>

                    <td>

                        <% if(item.kondisi=="Baru"){ %>

                            <span class="badge bg-success">

                                Baru

                            </span>

                        <% }else{ %>

                            <span class="badge bg-secondary">

                                Bekas

                            </span>

                        <% } %>

                    </td>

                    <td class="text-end">

                        Rp <%= Number(item.estimasi_harga||0).toLocaleString("id-ID") %>

                    </td>

                    <td>

                        <%= item.keterangan || "-" %>

                    </td>

                    <td>

                        <a
                        href="/transaksi/edit-donasi/<%= item.id %>"
                        class="btn btn-warning btn-sm">

                            ✏ Edit

                        </a>

                        <a
                        href="/transaksi/hapus-donasi/<%= item.id %>"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Hapus donasi barang ini?')">

                            🗑 Hapus

                        </a>

                    </td>

                </tr>

                <% }) %>

            <% }else{ %>

                <tr>

                    <td colspan="10" class="text-center text-muted">

                        Belum ada data donasi barang.

                    </td>

                </tr>

            <% } %>

            </tbody>

        </table>

    </div>

</div>
<!-- ===================================================== -->
<!-- RIWAYAT INVENTARIS MASJID -->
<!-- ===================================================== -->

<div class="card shadow-soft mt-4">

    <div class="card-header bg-primary text-white">

        <h5 class="mb-0">

            📦 Inventaris Masjid

        </h5>

    </div>

    <div class="card-body table-responsive">

        <table class="table table-bordered table-hover align-middle">

            <thead class="table-light">

                <tr>

                    <th width="40">No</th>

                    <th>Tanggal Masuk</th>

                    <th>Nama Aset</th>

                    <th>Kategori</th>

                    <th>Jumlah</th>

                    <th>Kondisi</th>

                    <th>Lokasi</th>

                    <th class="text-end">Nilai Estimasi</th>

                    <th>Keterangan</th>

                    <th width="170">Aksi</th>

                </tr>

            </thead>

            <tbody>

            <% if(inventaris && inventaris.length){ %>

                <% inventaris.forEach(function(item,index){ %>

                <tr>

                    <td>

                        <%= index+1 %>

                    </td>

                    <td>

                        <%= new Date(item.tanggal_masuk).toLocaleDateString("id-ID") %>

                    </td>

                    <td>

                        <strong>

                            <%= item.nama_aset %>

                        </strong>

                    </td>

                    <td>

                        <%= item.kategori || "-" %>

                    </td>

                    <td>

                        <%= item.jumlah %> <%= item.satuan %>

                    </td>

                    <td>

                        <% if(item.kondisi=="Baik"){ %>

                            <span class="badge bg-success">

                                Baik

                            </span>

                        <% }else if(item.kondisi=="Bekas"){ %>

                            <span class="badge bg-warning text-dark">

                                Bekas

                            </span>

                        <% }else{ %>

                            <span class="badge bg-danger">

                                Service

                            </span>

                        <% } %>

                    </td>

                    <td>

                        <%= item.lokasi || "-" %>

                    </td>

                    <td class="text-end">

                        Rp <%= Number(item.nilai_estimasi||0).toLocaleString("id-ID") %>

                    </td>

                    <td>

                        <%= item.keterangan || "-" %>

                    </td>

                    <td>

                        <a
                        href="/transaksi/edit-inventaris/<%= item.id %>"
                        class="btn btn-warning btn-sm">

                            ✏ Edit

                        </a>

                        <a
                        href="/transaksi/hapus-inventaris/<%= item.id %>"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Hapus inventaris ini?')">

                            🗑 Hapus

                        </a>

                    </td>

                </tr>

                <% }) %>

            <% }else{ %>

                <tr>

                    <td colspan="10" class="text-center text-muted">

                        Belum ada data inventaris.

                    </td>

                </tr>

            <% } %>

            </tbody>

        </table>

    </div>

</div>
<script>

/* =====================================================
   AUTO TANGGAL HARI INI
===================================================== */

document.addEventListener("DOMContentLoaded",function(){

    const today=new Date().toISOString().split("T")[0];

    [
        "tanggal_uang",
        "tanggal_donasi",
        "tanggal_inventaris"
    ].forEach(function(id){

        const el=document.getElementById(id);

        if(el && !el.value){

            el.value=today;

        }

    });

});


/* =====================================================
   SWITCH FORM
===================================================== */

const jenisInput=document.getElementById("jenis_input");

const formUang=document.getElementById("formUang");

const formDonasi=document.getElementById("formDonasi");

const formInventaris=document.getElementById("formInventaris");

function tampilkanForm(){

    formUang.style.display="none";
    formDonasi.style.display="none";
    formInventaris.style.display="none";

    if(jenisInput.value==="uang"){

        formUang.style.display="block";

    }

    if(jenisInput.value==="donasi"){

        formDonasi.style.display="block";

    }

    if(jenisInput.value==="inventaris"){

        formInventaris.style.display="block";

    }

}

tampilkanForm();

jenisInput.addEventListener("change",tampilkanForm);


/* =====================================================
   TUNAI / TRANSFER
===================================================== */

const metode=document.getElementById("metode");

const rekeningGroup=document.getElementById("rekeningGroup");

const rekeningSelect=document.getElementById("rekening_id");

function toggleRekening(){

    if(!metode) return;

    if(metode.value==="tunai"){

        rekeningGroup.style.display="none";

        rekeningSelect.value="";

        rekeningSelect.removeAttribute("required");

    }else{

        rekeningGroup.style.display="block";

        rekeningSelect.setAttribute("required","required");

    }

}

if(metode){

    toggleRekening();

    metode.addEventListener("change",toggleRekening);

}


/* =====================================================
   FORMAT INPUT ANGKA
===================================================== */

document.querySelectorAll("input[type='number']").forEach(function(el){

    el.addEventListener("wheel",function(){

        this.blur();

    });

});


/* =====================================================
   RESET FORM
===================================================== */

document.querySelectorAll("form").forEach(function(frm){

    frm.addEventListener("reset",function(){

        setTimeout(function(){

            tampilkanForm();

            toggleRekening();

        },100);

    });

});

</script>